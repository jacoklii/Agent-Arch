# Agent Arch - Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================================
# REQUIRED: Claude API Key
# Get yours at: https://console.anthropic.com
# Keys look like: sk-ant-api03-...
# ============================================================
CLAUDE_API_KEY=your-claude-api-key-here

# ============================================================
# REQUIRED: Session Secret
# Used to secure your session cookies
# Must be at least 32 random characters
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================
SESSION_SECRET=replace-this-with-a-32-plus-character-random-string

# ============================================================
# Environment
# ============================================================
NODE_ENV=development

# ============================================================
# Server Ports (optional - defaults shown)
# ============================================================
PORT=3001
